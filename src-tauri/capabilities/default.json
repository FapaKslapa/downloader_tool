{
  "identifier": "default",
  "description": "Default capability for the TubeGrab application",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "sidecar": "binaries/yt-dlp"
        },
        {
          "sidecar": "binaries/ffmpeg"
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "sidecar": "binaries/yt-dlp"
        },
        {
          "sidecar": "binaries/ffmpeg"
        }
      ]
    }
  ]
}
